{
  "name": "pustakaone",
  "version": "2.0.0",
  "description": "PustakaOne – Perpustakaan Digital Standalone",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js"
  },
  "dependencies": {
    "bcryptjs":    "^2.4.3",
    "express":     "^4.18.2",
    "jsonwebtoken":"^9.0.0",
    "multer":      "^1.4.5-lts.1",
    "sql.js":      "^1.10.3"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "targets": ["node18-win-x64"],
    "outputPath": "dist",
    "assets": [
      "client/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "scripts": [
      "server/**/*.js"
    ]
  }
}
